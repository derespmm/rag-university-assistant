__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Virtual environments
.venv/
venv/
env/
ENV/

# =============================================================
#  Node / Frontend
# =============================================================
node_modules/
dist/
.next/
.nuxt/
.cache/
*.local

# =============================================================
#  Data — PDFs and uploads are NOT committed
#  (too large, may contain sensitive info)
#  .gitkeep files inside these dirs preserve the folder in git
# =============================================================
data/policies/*
data/syllabi/*
data/sample_queries/*
!data/policies/.gitkeep
!data/syllabi/.gitkeep
!data/sample_queries/.gitkeep

# Scratch test scripts — not committed
tests/*
!tests/.gitkeep

# Uploaded syllabi (runtime temp storage)
backend/uploads/

# =============================================================
#  ChromaDB vector store — regenerated by ingest_policies.py
# =============================================================
chroma_db/
*.chroma

# =============================================================
#  OS & Editor
# =============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================
#  Misc
# =============================================================
*.log
*.tmp