# =============================================================
#  Copy this file to .env and fill in your values.
#  Never commit .env — it is gitignored.
# =============================================================

# OpenAI — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model selection (gpt-4o recommended; gpt-3.5-turbo for lower cost)
OPENAI_MODEL=gpt-4o

# ChromaDB — path where the vector store is persisted on disk
CHROMA_PATH=./chroma_db

# Embedding model (text-embedding-3-small is fast & cheap)
EMBEDDING_MODEL=text-embedding-3-small

# FastAPI
API_HOST=127.0.0.1
API_PORT=8000

# Frontend dev server (Vite default)
VITE_API_BASE_URL=http://127.0.0.1:8000
